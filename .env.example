# ============================================
# System Configuration
# ============================================
# Vault path (Obsidian directory)
VAULT_PATH=.

# Dry run mode (set to 'false' to enable real actions)
DRY_RUN=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# Security Settings
# ============================================
# Maximum actions per hour (rate limiting)
MAX_EMAILS_PER_HOUR=10
MAX_PAYMENTS_PER_HOUR=3
MAX_SOCIAL_POSTS_PER_HOUR=5
